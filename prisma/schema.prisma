generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id              String         @id @default(uuid())
  artistName      String
  songTitle       String
  genre           String?
  mood            String?
  audioUrl        String
  coverArtUrl     String
  autoLaunch      Boolean        @default(false)
  status          CampaignStatus @default(PENDING)
  metaCampaignId  String?
  visualConfig    Json?
  clipDefinitions Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String?
  spotifyUrl      String?
  lastSyncAt      DateTime?

  jobs                CampaignJob[]
  segments            AudioSegment[]
  creatives           VideoCreative[]
  adCopies            AdCopy[]
  audiences           Audience[]
  user                User?          @relation(fields: [userId], references: [id])
  insights            AdInsight[]
  smartLinkClicks     SmartLinkClick[]
  optimisationLogs    OptimisationLog[]
}

enum CampaignStatus {
  PENDING
  PROCESSING
  CONTENT_READY
  BUILDING
  READY
  LAUNCHING
  LIVE
  FAILED
  PAUSED
}

model CampaignJob {
  id         String    @id @default(uuid())
  campaignId String
  stage      JobStage
  status     JobStatus @default(PENDING)
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

enum JobStage {
  SEGMENTATION
  VIDEO_GEN
  COPY_GEN
  AUDIENCE_GEN
  META_SETUP
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model AudioSegment {
  id         String   @id @default(uuid())
  campaignId String
  fileUrl    String
  startSec   Float
  endSec     Float
  index      Int
  createdAt  DateTime @default(now())

  campaign  Campaign        @relation(fields: [campaignId], references: [id])
  creatives VideoCreative[]
}

model VideoCreative {
  id         String   @id @default(uuid())
  campaignId String
  segmentId  String
  fileUrl    String
  ctaText    String
  metaAdId   String?
  adStatus   String   @default("ACTIVE")
  createdAt  DateTime @default(now())

  campaign Campaign      @relation(fields: [campaignId], references: [id])
  segment  AudioSegment  @relation(fields: [segmentId], references: [id])
  adCopies AdCopy[]
}

model AdCopy {
  id          String   @id @default(uuid())
  campaignId  String
  creativeId  String
  headline    String
  primaryText String
  description String?
  createdAt   DateTime @default(now())

  campaign Campaign      @relation(fields: [campaignId], references: [id])
  creative VideoCreative @relation(fields: [creativeId], references: [id])
}

model Audience {
  id                String       @id @default(uuid())
  campaignId        String
  name              String
  type              AudienceType
  interests         String[]
  lookalikeSeed     String?
  retargetingSource String?
  metaAdSetId       String?
  availabilityNote  String?
  dataStatus        String?
  createdAt         DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

enum AudienceType {
  INTEREST
  RETARGETING
  LOOKALIKE
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  metaConnection  MetaConnection?
  campaigns       Campaign[]
  campaignCredits Int @default(0)
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AdInsight {
  id             String   @id @default(uuid())
  campaignId     String
  metaAdSetId    String?
  metaAdId       String?
  date           DateTime
  spend          Float    @default(0)
  impressions    Int      @default(0)
  cpm            Float    @default(0)
  ctr            Float    @default(0)
  cpc            Float    @default(0)
  outboundClicks Int      @default(0)
  videoViews     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, metaAdSetId, metaAdId, date])
  @@index([campaignId])
}

model SmartLinkClick {
  id          String   @id @default(uuid())
  campaignId  String
  platform    String?
  country     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model OptimisationLog {
  id            String   @id @default(uuid())
  campaignId    String
  metaAdSetId   String?
  metaAdId      String?
  action        String
  reason        String
  previousValue Float?
  newValue      Float?
  createdAt     DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// Tracks processed Stripe checkout sessions to prevent double-crediting
// when both the webhook and the verify fallback endpoint fire.
model StripeEvent {
  id        String   @id // Stripe checkout session ID (cs_...)
  userId    String
  createdAt DateTime @default(now())
}

model MetaConnection {
  id             String    @id @default(uuid())
  userId         String    @unique
  accessToken    String    @db.Text
  tokenExpiresAt DateTime?
  metaUserId     String
  adAccountId    String
  adAccountName  String?
  pageId         String
  pageName       String?
  pixelId        String?
  pixelName      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
